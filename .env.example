# ── Google Sheets ─────────────────────────────────────────────────────────────
# Local dev: path to service account JSON file
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=/path/to/service-account.json

# Production (Render): full JSON content as a single-line string
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

GOOGLE_SHEET_ID=your_google_sheet_id_here

# ── Gmail notifier ─────────────────────────────────────────────────────────────
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Comma-separated list of recipient emails
NOTIFY_EMAILS=you@gmail.com,spouse@gmail.com

# ── Map ────────────────────────────────────────────────────────────────────────
# Public URL of the deployed map (shown in email body). Set after Render deployment.
RENDER_MAP_URL=https://your-map.onrender.com/map.html

# ── Optional: Google Maps Distance Matrix (walk times) ────────────────────────
# Set to true to use real walking times instead of neighborhood approximations
USE_DISTANCE_MATRIX_API=false

# ── Optional: Google Geocoding API (listing coordinates) ──────────────────────
# Set to true to use Google Maps Geocoding instead of Nominatim (free, no key needed)
USE_GOOGLE_GEOCODING=false

# Required if either Google Maps feature above is enabled
GOOGLE_MAPS_API_KEY=
